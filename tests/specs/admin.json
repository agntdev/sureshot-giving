[
  {
    "name": "/admin shows access denied for non-owner",
    "steps": [
      {
        "send": { "text": "/admin" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "You don't have admin access." }
          }
        ]
      }
    ]
  },
  {
    "name": "Admin button shows access denied for non-owner",
    "steps": [
      {
        "send": { "callback": "admin:dashboard" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": { "text": "You don't have admin access." }
          }
        ]
      }
    ]
  }
]
